---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Dana Tovar for Smithville City Council, Place 5 | May 2, 2026">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container hero-container">
      <div class="hero-content">
        <h1 class="hero-title">Your neighbor. Your voice. Your council.</h1>
        <p class="hero-subhead">Dana Tovar for Smithville City Council, Place 5 | May 2, 2026</p>
        
        <div class="hero-ctas">
          <a href="/get-involved#yard-sign" class="btn btn-primary btn-large">Get a Yard Sign</a>
          <a href="/about" class="btn btn-secondary btn-large">Meet Dana</a>
        </div>
      </div>
      <div class="hero-image-placeholder">
        <div class="image-text">
          [ Placeholder: Photo of Dana in a recognizable Smithville setting ]
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="intro-section section">
    <div class="container intro-container">
      <div class="intro-text">
        <h2>A Neighbor Who Listens</h2>
        <p>
          I'm Dana Tovar, and I'm running for Smithville City Council, Place 5. After 15 years of calling this town home, I believe we deserve a council member who keeps the doors open, tells the truth about where our tax dollars go, and actually answers when you knock. I'm not a career politician. <strong>I'm a neighbor who has been paying attention.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Three Pillars Section -->
  <section class="pillars-section section">
    <div class="container">
      <div class="pillars-grid">
        <div class="pillar-card">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          </div>
          <h3>Transparency</h3>
          <p class="pillar-headline">"You deserve to know."</p>
          <p>I will advocate for plain-language budget summaries, public project updates, and open-door council communication.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <h3>Accessibility</h3>
          <p class="pillar-headline">"I answer the door."</p>
          <p>I commit to regular community office hours, responding to every resident inquiry, and attending neighborhood gatherings year-round.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          </div>
          <h3>Deep Roots</h3>
          <p class="pillar-headline">"15 years and counting."</p>
          <p>I have been part of Smithville's growth, its challenges, and its wins for a decade and a half. I care about what happens next.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Strip -->
  <section class="social-proof-section">
    <div class="container">
      <div class="quote-block">
        <blockquote>
          "Dana listens. When they were talking about development near our street, she was the only one who knocked on my door to ask what I thought about it. She's exactly what Smithville needs."
        </blockquote>
        <div class="quote-author">&mdash; Sarah M., The Colony Resident</div>
      </div>
    </div>
  </section>

  <!-- Mark Your Calendar -->
  <section class="calendar-section section">
    <div class="container calendar-container">
      <div class="calendar-content">
        <h2>Mark Your Calendar</h2>
        <p>Make a plan to vote. Your voice matters in local elections.</p>
        <div class="dates-grid">
          <div class="date-card">
            <div class="date-label">Early Voting Begins</div>
            <div class="date-value">April 20, 2026</div>
          </div>
          <div class="date-card primary-date">
            <div class="date-label">Election Day</div>
            <div class="date-value">May 2, 2026</div>
          </div>
        </div>
        <div class="calendar-cta">
          <a href="/get-involved#yard-sign" class="btn btn-primary btn-large">Request a Yard Sign Today</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero-section {
    background: linear-gradient(180deg, var(--color-background) 0%, #FFFFFF 100%);
    padding: 6rem 0;
  }
  
  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }
  
  .hero-subhead {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 2.5rem;
    font-weight: 500;
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
  }
  
  .hero-ctas {
    display: flex;
    gap: 1.5rem;
  }
  
  .btn-large {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }
  
  .hero-image-placeholder {
    aspect-ratio: 4/5;
    background-color: #E2E8F0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    color: #64748B;
    border: 2px dashed #CBD5E1;
    box-shadow: 0 10px 25px rgba(27, 58, 92, 0.1);
  }
  
  /* Intro Section */
  .intro-section {
    background-color: white;
    text-align: center;
    padding: 5rem 0;
  }
  
  .intro-container {
    max-width: 800px;
  }
  
  .intro-text h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }
  
  .intro-text p {
    font-size: 1.2rem;
    line-height: 1.8;
  }
  
  /* Pillars */
  .pillars-section {
    background-color: var(--color-background);
    padding: 6rem 0;
  }
  
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  
  .pillar-card {
    background: white;
    padding: 3rem 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    text-align: center;
    border-top: 4px solid var(--color-accent);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .pillar-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 20px rgba(0,0,0,0.1);
  }
  
  .pillar-icon {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
  }
  
  .pillar-card h3 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }
  
  .pillar-headline {
    font-style: italic;
    font-weight: 600;
    color: var(--color-highlight);
    margin-bottom: 1.5rem;
  }
  
  /* Social Proof */
  .social-proof-section {
    background-color: var(--color-primary);
    color: white;
    padding: 5rem 0;
    text-align: center;
    position: relative;
  }
  
  .social-proof-section::before {
    content: '"';
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 8rem;
    font-family: var(--font-heading);
    color: rgba(255, 255, 255, 0.1);
    line-height: 1;
  }
  
  .quote-block {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  .quote-block blockquote {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-style: italic;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    color: white;
  }
  
  .quote-author {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Calendar */
  .calendar-section {
    background-color: white;
    padding: 6rem 0;
  }
  
  .calendar-content {
    background-color: var(--color-background);
    padding: 4rem;
    border-radius: 12px;
    text-align: center;
    border: 1px solid rgba(27, 58, 92, 0.1);
    box-shadow: 0 20px 40px rgba(0,0,0,0.03);
  }
  
  .calendar-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .calendar-content > p {
    font-size: 1.25rem;
    margin-bottom: 3rem;
    color: #4B5563;
  }
  
  .dates-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .date-card {
    background: white;
    padding: 2.5rem 1rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  }
  
  .primary-date {
    border: 3px solid var(--color-highlight);
    box-shadow: 0 10px 25px rgba(184, 66, 51, 0.15);
  }
  
  .date-label {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }
  
  .primary-date .date-label {
    color: var(--color-highlight);
  }
  
  .date-value {
    font-family: var(--font-heading);
    color: var(--color-primary);
    font-size: 2.25rem;
    font-weight: 900;
  }
  
  @media (max-width: 900px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .hero-title {
      font-size: 2.5rem;
    }
    
    .hero-subhead {
      border-left: none;
      border-top: 4px solid var(--color-accent);
      padding-left: 0;
      padding-top: 1rem;
      display: inline-block;
    }
    
    .hero-ctas {
      justify-content: center;
      flex-direction: column;
    }
    
    .pillars-grid {
      grid-template-columns: 1fr;
    }
    
    .dates-grid {
      grid-template-columns: 1fr;
    }
    
    .quote-block blockquote {
      font-size: 1.4rem;
    }
    
    .calendar-content {
      padding: 3rem 1.5rem;
    }
  }
</style>
