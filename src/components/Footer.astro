---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-info">
      <h3>DAÑA TOVAR</h3>
      <p>for Smithville City Council, Place 5</p>
      <div class="social-links">
        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
      </div>
    </div>
    
    <div class="footer-nav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/why-im-running">Why I'm Running</a></li>
        <li><a href="/issues">Issues</a></li>
      </ul>
      <ul>
        <li><a href="/get-involved">Get Involved</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/get-involved#yard-sign">Yard Sign</a></li>
        <li><a href="/get-involved#volunteer">Volunteer</a></li>
      </ul>
    </div>
  </div>
  
  <div class="footer-bottom container">
    <div class="disclaimer">
      Paid for by Dana Tovar for Smithville City Council
    </div>
    <div class="copyright">
      &copy; {currentYear} Dana Tovar Campaign. All rights reserved.
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary);
    color: white;
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }
  
  .footer-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  
  .footer-info h3 {
    color: white;
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }
  
  .footer-info p {
    color: #A0B6CB;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  
  .social-links a {
    color: white;
    display: inline-block;
  }
  
  .social-links a:hover {
    color: var(--color-accent);
  }
  
  .footer-nav {
    display: flex;
    gap: 4rem;
    justify-content: flex-end;
  }
  
  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .footer-nav a {
    color: #A0B6CB;
  }
  
  .footer-nav a:hover {
    color: white;
  }
  
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2.5rem;
    text-align: center;
  }
  
  .disclaimer {
    border: 2px solid white;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    max-width: fit-content;
  }
  
  .copyright {
    color: #A0B6CB;
    font-size: 0.85rem;
  }
  
  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .footer-nav {
      justify-content: center;
      flex-direction: column;
      gap: 2rem;
    }
    
    .social-links {
      justify-content: center;
    }
  }
</style>
